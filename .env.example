# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. For LOCAL dev the Supabase values are printed by
# `pnpm db:start` (a.k.a. `supabase start`) — copy them from that output.
# ---------------------------------------------------------------------------

# Supabase (local stack uses the 553xx range to coexist with the `office`
# project on 543xx; anon/service keys come from `supabase start`)
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Next.js web app (T7) — public client needs the URL + anon key (same values)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic — script generation (T4). Optional: SCRIPT_MODEL (default claude-opus-4-8)
ANTHROPIC_API_KEY=
# SCRIPT_MODEL=claude-opus-4-8

# HeyGen — video generation (T5). All three required to submit a video.
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Worker tuning (optional — defaults shown)
# WORKER_MAX_CONCURRENCY=8
# HEYGEN_MAX_CONCURRENCY=10
# WORKER_VIDEO_POLL_DELAY_S=20
# WORKER_MAX_VIDEO_RETRIES=3
# WORKER_EST_VIDEO_DURATION_S=30
