# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. For LOCAL dev the Supabase values are printed by
# `pnpm db:start` (a.k.a. `supabase start`) — copy them from that output.
# ---------------------------------------------------------------------------

# Supabase (local stack uses the 553xx range to coexist with the `office`
# project on 543xx; anon/service keys come from `supabase start`)
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — script generation (T4)
ANTHROPIC_API_KEY=

# HeyGen — video generation (T5)
HEYGEN_API_KEY=
